// Prisma schema for Shyft — Neon (PostgreSQL) + better-auth
// Run: npx prisma generate && npx prisma db push

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────────────────────────────────────

enum UserRole {
  USER
  SUPERADMIN
}

enum AccountStatus {
  PENDING_REVIEW  // newly registered — awaiting SuperAdmin approval
  APPROVED        // approved, can access the dashboard
  REJECTED        // rejected by SuperAdmin
}

// ─────────────────────────────────────────────────────────────────────────────
// better-auth core tables
// ─────────────────────────────────────────────────────────────────────────────

model User {
  id                   String        @id @default(cuid())
  name                 String
  email                String        @unique
  emailVerified        Boolean       @default(false)
  image                String?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt
  onboardingCompleted  Boolean       @default(false)

  // ── Review system ──────────────────────────────────────────────────────────
  role                 UserRole      @default(USER)
  accountStatus        AccountStatus @default(PENDING_REVIEW)
  reviewNotes          String?       // SuperAdmin's message to the user
  reviewedAt           DateTime?     // when the account was last reviewed
  reviewedBy           String?       // SuperAdmin user id who reviewed

  sessions             Session[]
  accounts             Account[]

  @@map("user")
}

model Session {
  id        String   @id @default(cuid())
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?

  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("session")
}

model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("account")
}

model Verification {
  id         String    @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@map("verification")
}
