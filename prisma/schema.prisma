// Prisma schema for SHYFT — Neon (PostgreSQL) + better-auth
// Run: npx prisma generate && npx prisma db push

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────────────────────────────────────

enum UserRole {
  USER        // HR / Admin (org owner)
  EMPLOYEE    // Employee created by HR
  SUPERADMIN
}

enum AccountStatus {
  PENDING_REVIEW
  APPROVED
  REJECTED
}

enum CompanySize {
  SIZE_1_10
  SIZE_11_50
  SIZE_51_200
  SIZE_201_500
  SIZE_500_PLUS
}

enum EmploymentType {
  FULL_TIME
  PART_TIME
  CONTRACT
  INTERN
  FREELANCE
}

enum EmployeeStatus {
  ACTIVE
  INACTIVE
  ON_LEAVE
  TERMINATED
}

enum DayType {
  WORKING
  HOLIDAY
  LEAVE
  HALF_DAY
  WEEKEND
}

enum TimesheetStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
}

// ─────────────────────────────────────────────────────────────────────────────
// Organization — created by Admin during onboarding
// ─────────────────────────────────────────────────────────────────────────────

model Organization {
  id          String      @id @default(cuid())
  name        String
  slug        String      @unique
  logo        String?
  website     String?
  industry    String?
  size        CompanySize?
  description String?
  address     String?
  city        String?
  country     String?
  phone       String?

  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  ownerId     String      @unique
  owner       User        @relation("OrgOwner", fields: [ownerId], references: [id], onDelete: Cascade)

  employees   Employee[]
  departments Department[]
  positions   Position[]
  holidays    Holiday[]
  timesheets  Timesheet[]
  projects    Project[]

  @@map("organization")
}

// ─────────────────────────────────────────────────────────────────────────────
// Department
// ─────────────────────────────────────────────────────────────────────────────

model Department {
  id             String       @id @default(cuid())
  name           String
  description    String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([name, organizationId])
  @@map("department")
}

// ─────────────────────────────────────────────────────────────────────────────
// Position — job levels/titles within an organization
// ─────────────────────────────────────────────────────────────────────────────

model Position {
  id             String       @id @default(cuid())
  name           String       // e.g. "Team Lead", "Senior Developer", "Manager"
  description    String?
  level          Int?         // hierarchy level (1=entry, 2=mid, 3=senior, etc)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([name, organizationId])
  @@map("position")
}

// ─────────────────────────────────────────────────────────────────────────────
// Holiday — custom holidays set by HR for the organisation
// ─────────────────────────────────────────────────────────────────────────────

model Holiday {
  id             String       @id @default(cuid())
  name           String       // e.g. "Diwali", "Republic Day"
  date           DateTime     // the holiday date
  description    String?
  isRecurring    Boolean      @default(false) // repeats every year on same date

  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([date, organizationId])
  @@map("holiday")
}

// ─────────────────────────────────────────────────────────────────────────────
// Employee — created by Admin within their organization
// ─────────────────────────────────────────────────────────────────────────────

model Employee {
  id             String         @id @default(cuid())

  // ── Personal info ──────────────────────────────────────────────────────────
  firstName      String
  lastName       String
  email          String
  phone          String?
  avatar         String?
  dateOfBirth    DateTime?
  gender         String?
  address        String?

  // ── Professional info ──────────────────────────────────────────────────────
  employeeId     String?
  designation    String
  department     String?
  position       String?
  employmentType EmploymentType @default(FULL_TIME)
  status         EmployeeStatus @default(ACTIVE)

  // ── Employment dates ───────────────────────────────────────────────────────
  joiningDate    DateTime?
  leavingDate    DateTime?

  // ── Compensation ───────────────────────────────────────────────────────────
  salary         Float?
  currency       String?        @default("INR")

  // ── Emergency contact ──────────────────────────────────────────────────────
  emergencyName  String?
  emergencyPhone String?
  emergencyRel   String?

  // ── Access ─────────────────────────────────────────────────────────────────
  password           String?
  passwordCheck      String?
  passwordEncrypted  String?

  // ── Notes ──────────────────────────────────────────────────────────────────
  notes          String?

  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  // ── Relations ──────────────────────────────────────────────────────────────
  organizationId String
  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  // Link to User account for login
  userId         String?        @unique
  user           User?          @relation("EmployeeUser", fields: [userId], references: [id], onDelete: SetNull)

  // Reporting line
  reportingToId  String?
  reportingTo    Employee?      @relation("ReportingLine", fields: [reportingToId], references: [id], onDelete: SetNull)
  subordinates   Employee[]     @relation("ReportingLine")

  timesheets     Timesheet[]
  reviewedTimesheets Timesheet[] @relation("ReportingLeadReview")
  ledProjects    Project[]      @relation("ProjectLead")
  projects       ProjectMember[]

  @@unique([email, organizationId])
  @@map("employee")
}

// ─────────────────────────────────────────────────────────────────────────────
// Timesheet — monthly container per employee
// ─────────────────────────────────────────────────────────────────────────────

model Timesheet {
  id             String          @id @default(cuid())
  month          Int             // 1–12
  year           Int
  status         TimesheetStatus @default(DRAFT)
  submittedAt    DateTime?
  reviewedAt     DateTime?
  reviewedBy     String?         // HR/Admin user id
  rejectionNote  String?
  reportingLeadId String?
  reportingLead   Employee?       @relation("ReportingLeadReview", fields: [reportingLeadId], references: [id], onDelete: SetNull)

  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  employeeId     String
  employee       Employee        @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  organizationId String
  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  entries        TimesheetEntry[]

  @@unique([employeeId, month, year])
  @@map("timesheet")
}

// ─────────────────────────────────────────────────────────────────────────────
// TimesheetEntry — one row per day in the timesheet
// ─────────────────────────────────────────────────────────────────────────────

model TimesheetEntry {
  id             String     @id @default(cuid())
  date           DateTime   // the specific day (date only, time = 00:00:00 UTC)
  dayType        DayType    @default(WORKING)

  // ── Time fields (only for WORKING / HALF_DAY) ──────────────────────────────
  startTime      String?    // "HH:MM" 24h format e.g. "10:00"
  endTime        String?    // "HH:MM" 24h format e.g. "19:30"
  breakMinutes   Int?       @default(0)

  // ── Work description ───────────────────────────────────────────────────────
  workDone       String?    // plain text, can be multi-line

  // ── Reference links ────────────────────────────────────────────────────────
  links          String[]   // array of URLs

  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  timesheetId    String
  timesheet      Timesheet  @relation(fields: [timesheetId], references: [id], onDelete: Cascade)

  tasks          TimesheetTask[]

  @@unique([timesheetId, date])
  @@map("timesheet_entry")
}

model TimesheetTask {
  id               String         @id @default(cuid())
  startTime        String
  endTime          String
  subject          String
  description      String?
  isLearning       Boolean        @default(false)
  links            Json?          @default("[]")
  
  projectId        String?
  project          Project?       @relation(fields: [projectId], references: [id], onDelete: SetNull)
  
  timesheetEntryId String
  timesheetEntry   TimesheetEntry @relation(fields: [timesheetEntryId], references: [id], onDelete: Cascade)

  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@map("timesheet_task")
}

// ─────────────────────────────────────────────────────────────────────────────
// better-auth core tables
// ─────────────────────────────────────────────────────────────────────────────

model User {
  id                   String        @id @default(cuid())
  name                 String
  email                String        @unique
  emailVerified        Boolean       @default(false)
  image                String?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt
  onboardingCompleted  Boolean       @default(false)

  role                 UserRole      @default(USER)
  accountStatus        AccountStatus @default(PENDING_REVIEW)
  reviewNotes          String?
  reviewedAt           DateTime?
  reviewedBy           String?

  organization         Organization? @relation("OrgOwner")

  // Employee account link
  employeeProfile      Employee?     @relation("EmployeeUser")

  sessions             Session[]
  accounts             Account[]

  @@map("user")
}

model Session {
  id        String   @id @default(cuid())
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?

  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("session")
}

model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("account")
}

model Verification {
  id         String    @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@map("verification")
}

// ─────────────────────────────────────────────────────────────────────────────
// Project — work containers
// ─────────────────────────────────────────────────────────────────────────────

model Project {
  id             String       @id @default(cuid())
  name           String
  description    String?
  client         String?
  status         String       @default("active") // active, completed, paused
  color          String?      @default("bg-primary")
  budget         Float?       // in hours
  
  startDate      DateTime?
  endDate        DateTime?
  isLearning     Boolean      @default(false)
  
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  
  // Who created it / owns it
  leadId         String?
  lead           Employee?    @relation("ProjectLead", fields: [leadId], references: [id], onDelete: SetNull)
  
  // Members of the project
  members        ProjectMember[]
  timesheetTasks TimesheetTask[]

  @@map("project")
}

model ProjectMember {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  
  role       String?  // e.g. "Developer", "Designer"
  
  @@unique([projectId, employeeId])
  @@map("project_member")
}
