// Prisma schema for SHYFT — Neon (PostgreSQL) + better-auth
// Run: npx prisma generate && npx prisma db push

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────────────────────────────────────

enum UserRole {
  USER        // HR / Admin (org owner)
  EMPLOYEE    // Employee created by HR
  SUPERADMIN
}

enum AccountStatus {
  PENDING_REVIEW
  APPROVED
  REJECTED
}

enum CompanySize {
  SIZE_1_10
  SIZE_11_50
  SIZE_51_200
  SIZE_201_500
  SIZE_500_PLUS
}

enum EmploymentType {
  FULL_TIME
  PART_TIME
  CONTRACT
  INTERN
  FREELANCE
}

enum EmployeeStatus {
  ACTIVE
  INACTIVE
  ON_LEAVE
  TERMINATED
}

enum DayType {
  WORKING
  HOLIDAY
  LEAVE
  HALF_DAY
  WEEKEND
}

enum TimesheetStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
  HR_SUBMITTED   // Employee forwarded lead-approved timesheet to HR
  HR_APPROVED    // HR gave final approval (payroll ready)
}

// ─────────────────────────────────────────────────────────────────────────────
// Organization — created by Admin during onboarding
// ─────────────────────────────────────────────────────────────────────────────

model Organization {
  id          String      @id @default(cuid())
  name        String
  slug        String      @unique
  logo        String?
  website     String?
  industry    String?
  size        CompanySize?
  description String?
  address     String?
  city        String?
  country     String?
  phone       String?

  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  ownerId     String      @unique
  owner       User        @relation("OrgOwner", fields: [ownerId], references: [id], onDelete: Cascade)

  employees   Employee[]
  departments Department[]
  positions   Position[]
  holidays    Holiday[]
  timesheets  Timesheet[]
  projects    Project[]
  skills      Skill[]
  leaves      LeaveApplication[]
  compOffs    LeaveCompensation[]
  reimbursements Reimbursement[]
  assets      Asset[]
  assetRequests AssetRequest[]
  onboardings EmployeeOnboarding[]

  @@map("organization")
}

// ─────────────────────────────────────────────────────────────────────────────
// Department
// ─────────────────────────────────────────────────────────────────────────────

model Department {
  id             String       @id @default(cuid())
  name           String
  description    String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([name, organizationId])
  @@map("department")
}

// ─────────────────────────────────────────────────────────────────────────────
// Position — job levels/titles within an organization
// ─────────────────────────────────────────────────────────────────────────────

model Position {
  id             String       @id @default(cuid())
  name           String       // e.g. "Team Lead", "Senior Developer", "Manager"
  description    String?
  level          Int?         // hierarchy level (1=entry, 2=mid, 3=senior, etc)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([name, organizationId])
  @@map("position")
}

// ─────────────────────────────────────────────────────────────────────────────
// Holiday — custom holidays set by HR for the organisation
// ─────────────────────────────────────────────────────────────────────────────

model Holiday {
  id             String       @id @default(cuid())
  name           String       // e.g. "Diwali", "Republic Day"
  date           DateTime     // the holiday date
  description    String?
  isRecurring    Boolean      @default(false) // repeats every year on same date

  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([date, organizationId])
  @@map("holiday")
}

// ─────────────────────────────────────────────────────────────────────────────
// Employee — created by Admin within their organization
// ─────────────────────────────────────────────────────────────────────────────

model Employee {
  id             String         @id @default(cuid())

  // ── Personal info ──────────────────────────────────────────────────────────
  firstName      String
  lastName       String
  email          String
  phone          String?
  avatar         String?
  dateOfBirth    DateTime?
  gender         String?
  address        String?

  // ── Professional info ──────────────────────────────────────────────────────
  employeeId     String?
  designation    String
  department     String?
  position       String?
  employmentType EmploymentType @default(FULL_TIME)
  status         EmployeeStatus @default(ACTIVE)

  // ── Employment dates ───────────────────────────────────────────────────────
  joiningDate    DateTime?
  leavingDate    DateTime?

  // ── Compensation ───────────────────────────────────────────────────────────
  salary         Float?
  currency       String?        @default("INR")

  // ── Emergency contact ──────────────────────────────────────────────────────
  emergencyName  String?
  emergencyPhone String?
  emergencyRel   String?

  // ── Access ─────────────────────────────────────────────────────────────────
  password           String?
  passwordCheck      String?
  passwordEncrypted  String?

  // ── Notes ──────────────────────────────────────────────────────────────────
  notes          String?

  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  // ── Relations ──────────────────────────────────────────────────────────────
  organizationId String
  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  // Link to User account for login
  userId         String?        @unique
  user           User?          @relation("EmployeeUser", fields: [userId], references: [id], onDelete: SetNull)

  // Reporting line
  reportingToId  String?
  reportingTo    Employee?      @relation("ReportingLine", fields: [reportingToId], references: [id], onDelete: SetNull)
  subordinates   Employee[]     @relation("ReportingLine")

  timesheets     Timesheet[]
  reviewedTimesheets Timesheet[] @relation("ReportingLeadReview")
  ledProjects    Project[]      @relation("ProjectLead")
  projects       ProjectMember[]
  skills         EmployeeSkill[]
  leaves           LeaveApplication[] @relation("EmployeeLeaves")
  leavesAsReporter LeaveApplication[] @relation("LeaveReportingTo")
  compOffs         LeaveCompensation[] @relation("EmployeeCompOff")
  compOffsAsReporter LeaveCompensation[] @relation("CompOffReportingTo")
  reimbursements   Reimbursement[] @relation("EmployeeReimbursements")
  assignedAssets   Asset[]
  assetRequests    AssetRequest[] @relation("EmployeeAssetRequests")
  
  onboarding       EmployeeOnboarding?

  @@unique([email, organizationId])
  @@map("employee")
}

// ─────────────────────────────────────────────────────────────────────────────
// Timesheet — monthly container per employee
// ─────────────────────────────────────────────────────────────────────────────

model Timesheet {
  id             String          @id @default(cuid())
  month          Int             // 1–12
  year           Int
  status         TimesheetStatus @default(DRAFT)
  submittedAt    DateTime?
  reviewedAt     DateTime?
  reviewedBy     String?         // HR/Admin user id
  rejectionNote  String?
  reportingLeadId String?
  reportingLead   Employee?       @relation("ReportingLeadReview", fields: [reportingLeadId], references: [id], onDelete: SetNull)
  hrSubmittedAt  DateTime?       // when employee forwarded to HR after lead approval
  hrReviewedAt   DateTime?       // when HR gave final approval

  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  employeeId     String
  employee       Employee        @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  organizationId String
  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  entries        TimesheetEntry[]

  @@unique([employeeId, month, year])
  @@map("timesheet")
}

// ─────────────────────────────────────────────────────────────────────────────
// TimesheetEntry — one row per day in the timesheet
// ─────────────────────────────────────────────────────────────────────────────

model TimesheetEntry {
  id             String     @id @default(cuid())
  date           DateTime   // the specific day (date only, time = 00:00:00 UTC)
  dayType        DayType    @default(WORKING)

  // ── Time fields (only for WORKING / HALF_DAY) ──────────────────────────────
  startTime      String?    // "HH:MM" 24h format e.g. "10:00"
  endTime        String?    // "HH:MM" 24h format e.g. "19:30"
  breakMinutes   Int?       @default(0)

  // ── Work description ───────────────────────────────────────────────────────
  workDone       String?    // plain text, can be multi-line

  // ── Reference links ────────────────────────────────────────────────────────
  links          String[]   // array of URLs

  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  timesheetId    String
  timesheet      Timesheet  @relation(fields: [timesheetId], references: [id], onDelete: Cascade)

  tasks          TimesheetTask[]

  @@unique([timesheetId, date])
  @@map("timesheet_entry")
}

model TimesheetTask {
  id               String         @id @default(cuid())
  startTime        String
  endTime          String
  subject          String
  description      String?
  isLearning       Boolean        @default(false)
  links            Json?          @default("[]")
  
  projectId        String?
  project          Project?       @relation(fields: [projectId], references: [id], onDelete: SetNull)
  
  timesheetEntryId String
  timesheetEntry   TimesheetEntry @relation(fields: [timesheetEntryId], references: [id], onDelete: Cascade)

  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@map("timesheet_task")
}

// ─────────────────────────────────────────────────────────────────────────────
// better-auth core tables
// ─────────────────────────────────────────────────────────────────────────────

model User {
  id                   String        @id @default(cuid())
  name                 String
  email                String        @unique
  emailVerified        Boolean       @default(false)
  image                String?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt
  onboardingCompleted  Boolean       @default(false)

  role                 UserRole      @default(USER)
  accountStatus        AccountStatus @default(PENDING_REVIEW)
  reviewNotes          String?
  reviewedAt           DateTime?
  reviewedBy           String?

  organization         Organization? @relation("OrgOwner")

  // Employee account link
  employeeProfile      Employee?     @relation("EmployeeUser")

  sessions             Session[]
  accounts             Account[]

  @@map("user")
}

model Session {
  id        String   @id @default(cuid())
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?

  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("session")
}

model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("account")
}

model Verification {
  id         String    @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@map("verification")
}

// ─────────────────────────────────────────────────────────────────────────────
// Project — work containers
// ─────────────────────────────────────────────────────────────────────────────

model Project {
  id             String       @id @default(cuid())
  name           String
  description    String?
  client         String?
  status         String       @default("active") // active, completed, paused
  color          String?      @default("bg-primary")
  budget         Float?       // in hours
  
  startDate      DateTime?
  endDate        DateTime?
  isLearning     Boolean      @default(false)
  
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  
  // Who created it / owns it
  leadId         String?
  lead           Employee?    @relation("ProjectLead", fields: [leadId], references: [id], onDelete: SetNull)
  
  // Members of the project
  members        ProjectMember[]
  timesheetTasks TimesheetTask[]

  @@map("project")
}

model ProjectMember {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  
  role       String?  // e.g. "Developer", "Designer"
  
  @@unique([projectId, employeeId])
  @@map("project_member")
}

// ─────────────────────────────────────────────────────────────────────────────
// Skill — master skill library per organization
// ─────────────────────────────────────────────────────────────────────────────

enum SkillProficiency {
  BEGINNER      // Less than 30%
  INTERMEDIATE  // 30% to 70%
  PROFICIENT    // More than 70%
}

model Skill {
  id             String         @id @default(cuid())
  name           String
  category       String         // e.g. "Frontend", "Backend", "Database", "Tools", "Mobile", "DevOps"
  description    String?
  color          String?        @default("bg-primary") // accent color for the card

  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  organizationId String
  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  employeeSkills EmployeeSkill[]

  @@unique([name, organizationId])
  @@map("skill")
}

model EmployeeSkill {
  id          String           @id @default(cuid())
  proficiency SkillProficiency @default(BEGINNER)

  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  skillId     String
  skill       Skill            @relation(fields: [skillId], references: [id], onDelete: Cascade)

  employeeId  String
  employee    Employee         @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, skillId])
  @@map("employee_skill")
}

// ─────────────────────────────────────────────────────────────────────────────
// Leave Application
// ─────────────────────────────────────────────────────────────────────────────

enum LeaveType {
  FULL_DAY
  HALF_DAY
  MULTI_DAY
}

enum HalfDaySession {
  MORNING
  AFTERNOON
}

enum LeaveStatus {
  PENDING   // Submitted by employee, awaiting HR action
  APPROVED  // HR approved
  REJECTED  // HR rejected
}

model LeaveApplication {
  id               String          @id @default(cuid())
  leaveType        LeaveType
  halfDaySession   HalfDaySession?  // Only set when leaveType = HALF_DAY
  startDate        DateTime
  endDate          DateTime         // Same as startDate for FULL_DAY / HALF_DAY
  reason           String
  status           LeaveStatus     @default(PENDING)
  hrNote           String?          // HR comment on approval/rejection

  submittedAt      DateTime        @default(now())
  reviewedAt       DateTime?
  reviewedById     String?          // User id of the HR who acted

  // Denormalized at time of submission (historical accuracy)
  reportingToId    String?
  reportingTo      Employee?       @relation("LeaveReportingTo", fields: [reportingToId], references: [id], onDelete: SetNull)

  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  employeeId       String
  employee         Employee        @relation("EmployeeLeaves", fields: [employeeId], references: [id], onDelete: Cascade)

  organizationId   String
  organization     Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  notifications    Notification[]

  @@map("leave_application")
}

// ─────────────────────────────────────────────────────────────────────────────
// Notification
// ─────────────────────────────────────────────────────────────────────────────

enum NotificationType {
  LEAVE_SUBMITTED
  LEAVE_APPROVED
  LEAVE_REJECTED
  COMP_OFF_SUBMITTED
  COMP_OFF_ACKNOWLEDGED
  COMP_OFF_REJECTED
  REIMBURSEMENT_SUBMITTED
  REIMBURSEMENT_APPROVED
  REIMBURSEMENT_REJECTED
  REIMBURSEMENT_PAID
  ASSET_REQUEST_SUBMITTED
  ASSET_REQUEST_APPROVED
  ASSET_REQUEST_REJECTED
  ONBOARDING_SUBMITTED
  ONBOARDING_APPROVED
  ONBOARDING_REJECTED
}

enum CompDuration {
  HALF_DAY
  FULL_DAY
  OTHER
}

enum CompOffStatus {
  PENDING        // Submitted, awaiting HR acknowledgement
  ACKNOWLEDGED   // HR confirmed; leave treated as cleared
  REJECTED       // HR rejected (dates don't match policy, etc.)
}

model Notification {
  id          String           @id @default(cuid())
  type        NotificationType
  title       String
  message     String
  isRead      Boolean          @default(false)

  // Recipient: stored as userId (works for both USER and EMPLOYEE roles)
  recipientId String

  // Optional deep-link to the leave application
  leaveId     String?
  leave       LeaveApplication? @relation(fields: [leaveId], references: [id], onDelete: Cascade)

  // Optional deep-link to a comp-off request
  compOffId   String?
  compOff     LeaveCompensation? @relation(fields: [compOffId], references: [id], onDelete: Cascade)

  // Optional deep-link to a reimbursement request
  reimbursementId String?
  reimbursement   Reimbursement? @relation(fields: [reimbursementId], references: [id], onDelete: Cascade)

  // Optional deep-link to an asset request
  assetRequestId  String?
  assetRequest    AssetRequest? @relation(fields: [assetRequestId], references: [id], onDelete: Cascade)

  // Optional deep-link to onboarding
  onboardingId    String?
  onboarding      EmployeeOnboarding? @relation(fields: [onboardingId], references: [id], onDelete: Cascade)

  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([recipientId, isRead])
  @@map("notification")
}

// ─────────────────────────────────────────────────────────────────────────────
// Leave Compensation (Comp-Off)
// ─────────────────────────────────────────────────────────────────────────────

model LeaveCompensation {
  id               String        @id @default(cuid())

  // ── Compensation ON (the Saturday worked) ──────────────────────────────────
  compensationOn   DateTime      // The Saturday the employee came to office
  compOnDuration   CompDuration  // HALF_DAY | FULL_DAY | OTHER
  compOnOther      String?       // Only set when compOnDuration = OTHER

  // ── Compensation FOR (the leave taken) ────────────────────────────────────
  compensationFor  DateTime      // The date the employee had taken leave
  compForDuration  CompDuration  // HALF_DAY | FULL_DAY | OTHER
  compForOther     String?       // Only set when compForDuration = OTHER

  // ── Policy validation (computed at submission time, stored for audit) ──────
  isSameMonth      Boolean       // compensationOn.month === compensationFor.month

  // ── Additional info ────────────────────────────────────────────────────────
  awarenessNote    String        // Required — "No" or actual note

  // ── Workflow ───────────────────────────────────────────────────────────────
  status           CompOffStatus @default(PENDING)
  hrNote           String?       // HR comment on ack/rejection
  reviewedAt       DateTime?
  reviewedById     String?       // userId of HR who acted

  submittedAt      DateTime      @default(now())
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  // ── Relations ──────────────────────────────────────────────────────────────
  employeeId       String
  employee         Employee      @relation("EmployeeCompOff", fields: [employeeId], references: [id], onDelete: Cascade)

  reportingToId    String?       // Denormalized at submission time
  reportingTo      Employee?     @relation("CompOffReportingTo", fields: [reportingToId], references: [id], onDelete: SetNull)

  organizationId   String
  organization     Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  notifications    Notification[]

  @@unique([employeeId, compensationFor]) // One comp-off per leave date per employee
  @@map("leave_compensation")
}

// ─────────────────────────────────────────────────────────────────────────────
// Reimbursement Application
// ─────────────────────────────────────────────────────────────────────────────

enum ReimbursementStatus {
  PENDING   // Submitted, awaiting HR review
  APPROVED  // HR approved; pending finance payout
  REJECTED  // HR rejected
  PAID      // Finance confirmed payment to employee
}

enum ReimbursementCategory {
  TRAVEL
  FOOD
  CLIENT_MEETING
  EQUIPMENT
  OTHER
}

model ReimbursementProof {
  id               String          @id @default(cuid())
  fileName         String          // Original file name
  fileType         String          // MIME type
  fileSize         Int             // File size in bytes
  storageUrl       String          // Public URL from Cloudinary
  storagePublicId  String?         // Cloudinary public_id

  createdAt        DateTime        @default(now())

  reimbursementId  String
  reimbursement    Reimbursement   @relation(fields: [reimbursementId], references: [id], onDelete: Cascade)

  @@map("reimbursement_proof")
}

model Reimbursement {
  id              String                 @id @default(cuid())

  // ── Core fields ────────────────────────────────────────────────────────────
  amount          Float
  currency        String                 @default("INR")
  category        ReimbursementCategory  @default(OTHER)
  purpose         String                 // Details of the expense
  expenseDate     DateTime               // When the expense occurred

  // ── Workflow ───────────────────────────────────────────────────────────────
  status          ReimbursementStatus    @default(PENDING)
  hrNote          String?                // HR comment
  reviewedAt      DateTime?
  reviewedById    String?
  paidAt          DateTime?
  paidById        String?

  submittedAt     DateTime               @default(now())
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt

  // ── Relations ──────────────────────────────────────────────────────────────
  employeeId      String
  employee        Employee               @relation("EmployeeReimbursements", fields: [employeeId], references: [id], onDelete: Cascade)

  organizationId  String
  organization    Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  proofs          ReimbursementProof[]
  notifications   Notification[]

  @@map("reimbursement")
}

// ─────────────────────────────────────────────────────────────────────────────
// Asset Management & Requests
// ─────────────────────────────────────────────────────────────────────────────

enum AssetStatus {
  AVAILABLE
  ASSIGNED
  MAINTENANCE
  RETIRED
}

model Asset {
  id              String        @id @default(cuid())
  name            String        // "MacBook Pro M2", "Dell Ultrasharp"
  prodId          String        // The "Prod ID"
  type            String?       // "Laptop", "Monitor", "Phone"
  
  status          AssetStatus   @default(AVAILABLE)

  // Assignment
  assignedToId    String?
  assignedTo      Employee?     @relation(fields: [assignedToId], references: [id], onDelete: SetNull)
  assignedAt      DateTime?

  organizationId  String
  organization    Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  
  requests        AssetRequest[]

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@unique([organizationId, prodId])
  @@map("asset")
}

enum AssetAction {
  ACQUIRE
  REPLACE
  RETURN
}

enum AssetRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

model AssetRequest {
  id              String             @id @default(cuid())
  action          AssetAction
  
  // For ACQUIRE (free text of what they want)
  requestedAsset  String?            
  
  // For REPLACE or RETURN (must link to existing asset they are returning)
  assetId         String?
  asset           Asset?             @relation(fields: [assetId], references: [id], onDelete: SetNull)

  reason          String
  duration        String?            // "Permanent", "3 months"

  status          AssetRequestStatus @default(PENDING)
  hrNote          String?            // Reason for rejection or notes
  reviewedAt      DateTime?
  reviewedById    String?            // userId of HR

  employeeId      String
  employee        Employee           @relation("EmployeeAssetRequests", fields: [employeeId], references: [id], onDelete: Cascade)

  organizationId  String
  organization    Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  notifications   Notification[]

  submittedAt     DateTime           @default(now())
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  @@map("asset_request")
}

// ─────────────────────────────────────────────────────────────────────────────
// Employee Onboarding
// ─────────────────────────────────────────────────────────────────────────────

enum OnboardingStatus {
  PENDING_SUBMISSION
  UNDER_REVIEW
  APPROVED
  REJECTED
}

model EmployeeOnboarding {
  id                      String   @id @default(cuid())

  // Personal Info
  contactNumber           String
  emergencyContactNumber  String
  currentAddress          String
  permanentAddress        String
  dateOfBirth             DateTime
  isExperienced           Boolean  @default(false)

  // Document URLs (Cloudinary)
  passbookUrl             String
  panCardUrl              String
  aadhaarCardUrl          String
  marksheet10thUrl        String
  marksheet12thUrl        String
  marksheetGraduationUrl  String
  
  // Conditional Documents
  salarySlipUrl           String?
  experienceLetterUrl     String?
  relievingLetterUrl      String?

  // Images
  passportPhotoUrl        String
  casualPhotoUrl          String

  // Workflow
  status                  OnboardingStatus @default(PENDING_SUBMISSION)
  hrNote                  String? 
  
  // Relations
  employeeId              String  @unique
  employee                Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  
  organizationId          String
  organization            Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  notifications           Notification[]

  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  @@map("employee_onboarding")
}

